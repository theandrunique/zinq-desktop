{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Zinq Desktop",
  "version": "0.1.0",
  "identifier": "com.zinq.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Zinq Desktop",
        "width": 850,
        "height": 500,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#0e0e10",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
